# Supabase savienojums (aizpildi ar īstajām vērtībām .env failā)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IUB atvērto datu serviss (e-veidlapas). Aizpilda, kad gatavs reālai ievākšanai.
IUB_OPENDATA_BASE_URL=
IUB_FETCH_FROM=2023-10-01

# Minimālais parauga slieksnis pasūtītāja agregātam (B1 specifikācija: ieteicams 10)
MIN_SAMPLE_SIZE=10
